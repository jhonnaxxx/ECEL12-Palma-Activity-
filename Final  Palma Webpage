<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jhonna M. Palma | ECE Student</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            color: #4a235a;
            background: linear-gradient(135deg, #fce4ec 0%, #f3e5f5 50%, #e8eaf6 100%);
            min-height: 100vh;
        }
        
        .container {
            max-width: 1100px;
            margin: auto;
            padding: 0 20px;
        }
        
        /* Header */
        header {
            background: linear-gradient(135deg, #c2185b 0%, #7b1fa2 50%, #4a148c 100%);
            color: white;
            padding: 80px 0;
            text-align: center;
        }
        
        .profile-img {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            border: 4px solid #f8bbd0;
            margin-bottom: 20px;
            background: linear-gradient(135deg, #f8bbd0, #e1bee7);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 60px;
            box-shadow: 0 8px 25px rgba(194, 24, 91, 0.3);
            transition: transform 0.3s;
        }
        
        .profile-img:hover {
            transform: scale(1.05);
        }
        
        header h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }
        
        header p {
            font-size: 1.2rem;
            opacity: 0.95;
        }
        
        .badge {
            display: inline-block;
            background: rgba(255,255,255,0.25);
            padding: 8px 20px;
            border-radius: 30px;
            margin-top: 15px;
            font-size: 0.9rem;
            backdrop-filter: blur(5px);
        }
        
        /* Navigation */
        nav {
            background: linear-gradient(135deg, #880e4f 0%, #6a1b9a 100%);
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }
        
        nav ul {
            list-style: none;
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
        }
        
        nav ul li {
            padding: 15px 25px;
        }
        
        nav ul li a {
            color: white;
            text-decoration: none;
            font-weight: bold;
            transition: all 0.3s;
            font-size: 1rem;
        }
        
        nav ul li a:hover {
            color: #f8bbd0;
            text-shadow: 0 0 8px rgba(248,187,208,0.5);
        }
        
        /* Sections */
        section {
            padding: 60px 0;
            margin-bottom: 25px;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(2px);
            box-shadow: 0 5px 20px rgba(128, 0, 128, 0.08);
        }
        
        section:nth-child(even) {
            background: rgba(255, 255, 255, 0.92);
        }
        
        h2 {
            text-align: center;
            margin-bottom: 40px;
            color: #6a1b9a;
            font-size: 2rem;
            position: relative;
        }
        
        h2:after {
            content: '';
            display: block;
            width: 60px;
            height: 4px;
            background: linear-gradient(90deg, #e91e63, #9c27b0);
            margin: 12px auto 0;
            border-radius: 2px;
        }
        
        /* About */
        .about-content {
            max-width: 700px;
            margin: auto;
            text-align: center;
            font-size: 1.1rem;
            color: #4a235a;
        }
        
        /* Info Cards */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
            margin-top: 30px;
        }
        
        .info-card {
            background: linear-gradient(135deg, #ffffff 0%, #fce4ec 100%);
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(156, 39, 176, 0.15);
            text-align: center;
            transition: all 0.3s;
            border: 1px solid rgba(233, 30, 99, 0.2);
        }
        
        .info-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(156, 39, 176, 0.25);
            border-color: #e91e63;
        }
        
        .info-icon {
            font-size: 45px;
            margin-bottom: 15px;
        }
        
        .info-card h3 {
            color: #c2185b;
            margin-bottom: 10px;
        }
        
        /* Skills */
        .skills-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 25px;
            text-align: center;
        }
        
        .skill-card {
            background: linear-gradient(135deg, #fce4ec 0%, #f3e5f5 100%);
            padding: 30px 20px;
            border-radius: 15px;
            transition: all 0.3s;
            border: 1px solid rgba(233, 30, 99, 0.15);
        }
        
        .skill-card:hover {
            transform: translateY(-5px);
            background: linear-gradient(135deg, #e91e63 0%, #9c27b0 100%);
            color: white;
            box-shadow: 0 10px 25px rgba(233, 30, 99, 0.3);
        }
        
        .skill-card:hover h3,
        .skill-card:hover p {
            color: white;
        }
        
        .skill-card h3 {
            margin-bottom: 12px;
            color: #c2185b;
        }
        
        .skill-card p {
            color: #6a1b9a;
        }
        
        /* Subjects */
        .subjects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
            gap: 20px;
        }
        
        .subject-item {
            background: linear-gradient(135deg, #f8bbd0 0%, #e1bee7 100%);
            padding: 15px 20px;
            border-radius: 12px;
            text-align: center;
            font-weight: bold;
            color: #4a148c;
            transition: all 0.3s;
            cursor: default;
        }
        
        .subject-item:hover {
            transform: scale(1.02);
            background: linear-gradient(135deg, #e91e63 0%, #ab47bc 100%);
            color: white;
            box-shadow: 0 5px 15px rgba(233, 30, 99, 0.3);
        }
        
        /* Contact */
        .contact-info {
            text-align: center;
        }
        
        .contact-item {
            display: inline-block;
            margin: 10px 12px;
            padding: 12px 28px;
            background: linear-gradient(135deg, #e91e63 0%, #9c27b0 100%);
            color: white;
            text-decoration: none;
            border-radius: 40px;
            transition: all 0.3s;
            font-weight: 500;
            box-shadow: 0 4px 12px rgba(156, 39, 176, 0.3);
        }
        
        .contact-item:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(233, 30, 99, 0.4);
            background: linear-gradient(135deg, #c2185b 0%, #7b1fa2 100%);
        }
        
        /* Footer */
        footer {
            background: linear-gradient(135deg, #4a148c 0%, #880e4f 100%);
            color: white;
            text-align: center;
            padding: 25px;
            margin-top: 30px;
            border-radius: 20px 20px 0 0;
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            nav ul {
                flex-direction: column;
                text-align: center;
            }
            
            nav ul li {
                padding: 10px;
            }
            
            header h1 {
                font-size: 1.8rem;
            }
            
            .skills-grid, .subjects-grid {
                grid-template-columns: 1fr;
            }
            
            section {
                padding: 40px 0;
            }
            
            .contact-item {
                display: block;
                margin: 10px 20px;
            }
        }
        
        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 10px;
        }
        
        ::-webkit-scrollbar-track {
            background: #f3e5f5;
        }
        
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, #e91e63, #9c27b0);
            border-radius: 5px;
        }
        
        ::-webkit-scrollbar-thumb:hover {
            background: #c2185b;
        }
        
        /* Selection Color */
        ::selection {
            background: #e91e63;
            color: white;
        }
    </style>
</head>
